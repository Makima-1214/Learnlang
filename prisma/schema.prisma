// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// User model with role-based access
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  username  String?  @unique
  password  String
  avatar    String?  @db.Text
  bio       String?  @db.Text
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  histories History[]
  blogs     Blog[]
  comments  Comment[]
  reactions Reaction[]
  quizzes   Quiz[]
  quizResults QuizResult[]
  rooms     Room[]
  messages  Message[]
  
  @@map("users")
}

enum Role {
  USER
  ADMIN
}

// History model to store learning progress
model History {
  id                 String   @id @default(cuid())
  userId             String
  mode               Mode     // EN_ID or ID_EN
  sourceLanguage     String   // "en" or "id"
  targetLanguage     String   // "id" or "en"
  sourceSentence     String   @db.Text
  userTranslation    String   @db.Text
  correctTranslation String   @db.Text
  score              Int
  status             Status
  feedback           String   @db.Text
  difficulty         Difficulty
  createdAt          DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([createdAt])
  @@map("histories")
}

enum Mode {
  EN_ID  // English to Indonesian
  ID_EN  // Indonesian to English
}

enum Status {
  BENAR
  HAMPIR_BENAR
  SALAH
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

// Blog model
model Blog {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String   @db.LongText
  excerpt     String   @db.Text
  coverImage  String?  @db.Text
  published   Boolean  @default(false)
  authorId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments Comment[]
  reactions Reaction[]

  @@index([authorId])
  @@index([slug])
  @@index([published])
  @@map("blogs")
}

// Comment model
model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  blogId    String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  blog Blog @relation(fields: [blogId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([blogId])
  @@index([userId])
  @@index([createdAt])
  @@map("comments")
}

// Reaction model
model Reaction {
  id        String   @id @default(cuid())
  emoji     String   // emoji character like 👍, ❤️, 😂, etc.
  blogId    String
  userId    String
  createdAt DateTime @default(now())

  blog Blog @relation(fields: [blogId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([blogId, userId, emoji]) // One user can only react with the same emoji once per blog
  @@index([blogId])
  @@index([userId])
  @@map("reactions")
}

// Quiz model
model Quiz {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  published   Boolean  @default(false)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User @relation(fields: [createdById], references: [id], onDelete: Cascade)
  questions QuizQuestion[]
  results   QuizResult[]

  @@index([createdById])
  @@index([published])
  @@map("quizzes")
}

// Quiz Question model
model QuizQuestion {
  id       String @id @default(cuid())
  quizId   String
  question String @db.Text // The word or phrase to translate
  order    Int    // Question order in the quiz
  
  quiz    Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  options QuizOption[]

  @@index([quizId])
  @@map("quiz_questions")
}

// Quiz Option model (multiple choice answers)
model QuizOption {
  id         String  @id @default(cuid())
  questionId String
  option     String  @db.Text // The answer option
  isCorrect  Boolean @default(false)
  order      Int     // Option order
  
  question QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("quiz_options")
}

// Quiz Result model (stores user's quiz attempts)
model QuizResult {
  id          String   @id @default(cuid())
  quizId      String
  userId      String
  score       Int      // Number of correct answers
  totalQuestions Int   // Total questions in quiz
  answers     String   @db.LongText // JSON string of user answers
  completedAt DateTime @default(now())

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([quizId])
  @@index([userId])
  @@index([completedAt])
  @@map("quiz_results")
}

// Discussion Room model
model Room {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  isDefault   Boolean  @default(false) // Default room for general discussion
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User      @relation(fields: [createdById], references: [id], onDelete: Cascade)
  messages  Message[]

  @@index([createdById])
  @@index([isDefault])
  @@map("rooms")
}

// Chat Message model
model Message {
  id        String   @id @default(cuid())
  content   String   @db.Text
  roomId    String
  userId    String
  createdAt DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([userId])
  @@index([createdAt])
  @@map("messages")
}
