// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// User model with role-based access
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  histories History[]
  blogs     Blog[]
  comments  Comment[]
  reactions Reaction[]
  
  @@map("users")
}

enum Role {
  USER
  ADMIN
}

// History model to store learning progress
model History {
  id                 String   @id @default(cuid())
  userId             String
  mode               Mode     // EN_ID or ID_EN
  sourceLanguage     String   // "en" or "id"
  targetLanguage     String   // "id" or "en"
  sourceSentence     String   @db.Text
  userTranslation    String   @db.Text
  correctTranslation String   @db.Text
  score              Int
  status             Status
  feedback           String   @db.Text
  difficulty         Difficulty
  createdAt          DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([createdAt])
  @@map("histories")
}

enum Mode {
  EN_ID  // English to Indonesian
  ID_EN  // Indonesian to English
}

enum Status {
  BENAR
  HAMPIR_BENAR
  SALAH
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

// Blog model
model Blog {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String   @db.LongText
  excerpt     String   @db.Text
  coverImage  String?  @db.Text
  published   Boolean  @default(false)
  authorId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments Comment[]
  reactions Reaction[]

  @@index([authorId])
  @@index([slug])
  @@index([published])
  @@map("blogs")
}

// Comment model
model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  blogId    String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  blog Blog @relation(fields: [blogId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([blogId])
  @@index([userId])
  @@index([createdAt])
  @@map("comments")
}

// Reaction model
model Reaction {
  id        String   @id @default(cuid())
  emoji     String   // emoji character like 👍, ❤️, 😂, etc.
  blogId    String
  userId    String
  createdAt DateTime @default(now())

  blog Blog @relation(fields: [blogId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([blogId, userId, emoji]) // One user can only react with the same emoji once per blog
  @@index([blogId])
  @@index([userId])
  @@map("reactions")
}
