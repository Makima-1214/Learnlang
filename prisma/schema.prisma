// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// User model with role-based access
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  username  String?  @unique
  password  String
  avatar    String?  @db.Text
  bio       String?  @db.Text
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  histories     History[]
  blogs         Blog[]
  comments      Comment[]
  reactions     Reaction[]
  quizzes       Quiz[]
  quizResults   QuizResult[]
  rooms         Room[]
  messages      Message[]
  
  // Friend relationships
  followers     Follow[]  @relation("follower")
  following     Follow[]  @relation("following")
  friendsInitiated Friendship[] @relation("initiator")
  friendsReceived  Friendship[] @relation("friend")
  
  // Friend Requests
  friendRequestsSent FriendRequest[] @relation("sender")
  friendRequestsReceived FriendRequest[] @relation("receiver")
  
  // Blocked Users
  blockedUsers BlockedUser[] @relation("blocker")
  blockedByUsers BlockedUser[] @relation("blocked")
  
  // Private Messages
  sentMessages PrivateMessage[] @relation("sender")
  receivedMessages PrivateMessage[] @relation("receiver")
  
  // Activity Feed
  activities Activity[]
  // Notifications inbox
  notifications Notification[]
  
  @@map("users")
}

enum Role {
  USER
  ADMIN
}

// History model to store learning progress
model History {
  id                 String   @id @default(cuid())
  userId             String
  mode               Mode     // EN_ID or ID_EN
  sourceLanguage     String   // "en" or "id"
  targetLanguage     String   // "id" or "en"
  sourceSentence     String   @db.Text
  userTranslation    String   @db.Text
  correctTranslation String   @db.Text
  score              Int
  status             Status
  feedback           String   @db.Text
  difficulty         Difficulty
  createdAt          DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([createdAt])
  @@map("histories")
}

enum Mode {
  EN_ID  // English to Indonesian
  ID_EN  // Indonesian to English
}

enum Status {
  BENAR
  HAMPIR_BENAR
  SALAH
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

// Blog model
model Blog {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String   @db.LongText
  excerpt     String   @db.Text
  coverImage  String?  @db.Text
  published   Boolean  @default(false)
  authorId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments Comment[]
  reactions Reaction[]

  @@index([authorId])
  @@index([slug])
  @@index([published])
  @@map("blogs")
}

// Comment model
model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  blogId    String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  blog Blog @relation(fields: [blogId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([blogId])
  @@index([userId])
  @@index([createdAt])
  @@map("comments")
}

// Reaction model
model Reaction {
  id        String   @id @default(cuid())
  emoji     String   // emoji character like 👍, ❤️, 😂, etc.
  blogId    String
  userId    String
  createdAt DateTime @default(now())

  blog Blog @relation(fields: [blogId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([blogId, userId, emoji]) // One user can only react with the same emoji once per blog
  @@index([blogId])
  @@index([userId])
  @@map("reactions")
}

// Quiz model
model Quiz {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  published   Boolean  @default(false)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User @relation(fields: [createdById], references: [id], onDelete: Cascade)
  questions QuizQuestion[]
  results   QuizResult[]

  @@index([createdById])
  @@index([published])
  @@map("quizzes")
}

// Quiz Question model
model QuizQuestion {
  id       String @id @default(cuid())
  quizId   String
  question String @db.Text // The word or phrase to translate
  order    Int    // Question order in the quiz
  
  quiz    Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  options QuizOption[]

  @@index([quizId])
  @@map("quiz_questions")
}

// Quiz Option model (multiple choice answers)
model QuizOption {
  id         String  @id @default(cuid())
  questionId String
  option     String  @db.Text // The answer option
  isCorrect  Boolean @default(false)
  order      Int     // Option order
  
  question QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("quiz_options")
}

// Quiz Result model (stores user's quiz attempts)
model QuizResult {
  id          String   @id @default(cuid())
  quizId      String
  userId      String
  score       Int      // Number of correct answers
  totalQuestions Int   // Total questions in quiz
  answers     String   @db.LongText // JSON string of user answers
  completedAt DateTime @default(now())

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([quizId])
  @@index([userId])
  @@index([completedAt])
  @@map("quiz_results")
}

// Discussion Room model
model Room {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  isDefault   Boolean  @default(false) // Default room for general discussion
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User      @relation(fields: [createdById], references: [id], onDelete: Cascade)
  messages  Message[]

  @@index([createdById])
  @@index([isDefault])
  @@map("rooms")
}

// Chat Message model
model Message {
  id        String   @id @default(cuid())
  content   String   @db.Text
  roomId    String
  userId    String
  createdAt DateTime @default(now())
  isDeleted Boolean  @default(false)
  deletedAt DateTime?
  deletedBy String? // userId of who deleted the message (admin or the message owner)
  deletionReason String? // "user" or "admin"

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([userId])
  @@index([createdAt])
  @@map("messages")
}
// Follow model - tracks who follows whom
model Follow {
  id          String   @id @default(cuid())
  followerId  String   // User who follows
  followingId String   // User being followed
  createdAt   DateTime @default(now())

  follower  User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId]) // A user can only follow another once
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

// Friendship model - tracks mutual friendships (both follow each other)
model Friendship {
  id         String   @id @default(cuid())
  initiatorId String  // User who initiated the friendship (or first to follow)
  friendId   String   // The friend
  createdAt  DateTime @default(now())

  initiator User @relation("initiator", fields: [initiatorId], references: [id], onDelete: Cascade)
  friend    User @relation("friend", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([initiatorId, friendId]) // A friendship only exists once between two users
  @@index([initiatorId])
  @@index([friendId])
  @@map("friendships")
}

// Friend Request model - tracks pending friend requests
model FriendRequest {
  id         String   @id @default(cuid())
  senderId   String   // User sending request
  receiverId String   // User receiving request
  status     RequestStatus @default(PENDING)
  createdAt  DateTime @default(now())
  respondedAt DateTime?

  sender   User @relation("sender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("receiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId]) // Only one request between two users
  @@index([senderId])
  @@index([receiverId])
  @@index([status])
  @@map("friend_requests")
}

enum RequestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

// Blocked User model - tracks blocked relationships
model BlockedUser {
  id        String   @id @default(cuid())
  blockerId String   // User who blocked
  blockedId String   // User being blocked
  reason    String?  @db.Text
  createdAt DateTime @default(now())

  blocker User @relation("blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId]) // A user can only block another once
  @@index([blockerId])
  @@index([blockedId])
  @@map("blocked_users")
}

// Private Message model - direct messaging between friends
model PrivateMessage {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  content    String   @db.Text
  attachmentUrl String? @db.Text
  attachmentName String? @db.Text
  attachmentType String? @db.Text
  attachmentSize Int?
  attachmentCaption String? @db.Text
  createdAt  DateTime @default(now())
  isRead     Boolean  @default(false)
  readAt     DateTime?
  isDeleted  Boolean  @default(false)

  sender   User @relation("sender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("receiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
  @@map("private_messages")
}

// Activity Feed model - tracks user activities
model Activity {
  id        String   @id @default(cuid())
  userId    String
  type      ActivityType // "lesson_completed", "quiz_passed", "blog_published", "friend_added"
  title     String
  description String? @db.Text
  metadata  String?  @db.LongText // Store additional data as JSON string
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([type])
  @@map("activities")
}

enum ActivityType {
  LESSON_COMPLETED
  QUIZ_PASSED
  BLOG_PUBLISHED
  BLOG_COMMENTED
  FRIEND_ADDED
  FRIEND_ACCEPTED
}

enum NotificationType {
  // Social/Friends
  FOLLOW
  FRIEND_REQUEST
  FRIEND_REQUEST_ACCEPTED
  FRIEND_ADDED
  UNFOLLOW
  
  // Blog/Content
  BLOG_COMMENT
  BLOG_COMMENT_REPLY
  BLOG_REACTION
  BLOG_PUBLISHED
  
  // Quiz/Learning
  QUIZ_CREATED
  QUIZ_SHARED
  QUIZ_RESULT
  LESSON_COMPLETED
  
  // Chat/Messages
  MESSAGE_RECEIVED
  GROUP_MESSAGE
  
  // Discussion
  ROOM_MESSAGE
  ROOM_CREATED
  
  // System
  SYSTEM
  ANNOUNCEMENT
}

// Notification model - persistent user inbox
model Notification {
  id          String           @id @default(cuid())
  userId      String           // recipient
  type        NotificationType @default(SYSTEM)
  title       String
  description String?          @db.Text
  icon        String?          @db.Text // icon name or emoji
  link        String?          @db.Text // optional link for action
  isRead      Boolean          @default(false)
  metadata    String?          @db.LongText // JSON string for additional data
  createdAt   DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([type])
  @@map("notifications")
}
